{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/refresh-social?cohort=unsynced",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/refresh-social?cohort=active",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/refresh-social?cohort=avatars",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/resend-confirmations",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/nudge-profiles",
      "schedule": "30 8 * * *"
    },
    {
      "path": "/api/cron/licence-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
