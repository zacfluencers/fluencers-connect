{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/refresh-social?cohort=unsynced",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/refresh-social?cohort=active",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/refresh-social?cohort=avatars",
      "schedule": "30 6 * * *"
    }
  ]
}
