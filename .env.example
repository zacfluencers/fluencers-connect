# ---------------------------------------------------------------------------
# Example environment variables — PLACEHOLDERS ONLY, no real secrets.
#
# Local dev:  copy this file to `.env.local` and fill in real values.
# Production: set the same keys in Vercel → Project → Settings → Environment
#             Variables (Production + Preview). Never commit real values.
#
# Which side each key runs on:
#   NEXT_PUBLIC_*  -> exposed to the browser (safe: publishable/anon keys, URLs)
#   everything else -> server-only secrets, never sent to the client
# ---------------------------------------------------------------------------

# --- Supabase --------------------------------------------------------------
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# SECRET — server only. Used by the Stripe webhook + escrow writes (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# --- Stripe ----------------------------------------------------------------
# Stripe dashboard → Developers → API keys
# Publishable key is safe to expose to the browser (hence NEXT_PUBLIC_).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# SECRET — server only. NEVER prefix this with NEXT_PUBLIC.
STRIPE_SECRET_KEY=sk_test_xxx
# Signing secret for the webhook endpoint (Developers → Webhooks → your endpoint).
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optional platform fee in basis points (1000 = 10%). Defaults to 0 if unset.
PLATFORM_FEE_BPS=0

# Brand subscription plans (Stripe Billing). These hold the *lookup key* of each
# recurring Price (set a lookup key on the Price in the Stripe dashboard). A raw
# price_… id also works if you prefer. Both plans are shown on the brand dashboard.
STRIPE_PRICE_BRAND_WEEKLY_LOOKUP_KEY=brand_weekly
STRIPE_PRICE_BRAND_ANNUAL_LOOKUP_KEY=brand_annual

# --- Social enrichment (ScrapeCreators) ------------------------------------
# SECRET — server only. Powers the creator "Auto-fill from social profiles"
# button + scheduled refresh. NEVER prefix with NEXT_PUBLIC. Get it from your
# ScrapeCreators dashboard.
SCRAPECREATORS_API_KEY=your-scrapecreators-secret
# Optional: shared secret that guards the scheduled refresh route
# (/api/cron/refresh-social). Required before wiring up Vercel Cron.
CRON_SECRET=your-random-cron-secret

# --- App -------------------------------------------------------------------
# Absolute site URL, used to build Stripe redirect/return URLs.
# On Vercel you can leave this and the code falls back to VERCEL_URL, but
# setting it to your canonical domain is recommended.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
